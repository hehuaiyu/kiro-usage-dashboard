import { VerticalBox, HorizontalBox, ScrollView, ListView } from "std-widgets.slint";

// 一条按日柱状数据
export struct BarItem {
    label: string,   // MM-DD
    value: string,   // 显示值
    ratio: float,    // 0.0 ~ 1.0 柱高比例
}

// 明细表一行
export struct DetailRow {
    time: string,
    credits: string,
    elapsed: string,
    status: string,
    workspace: string,
    title: string,
}

// 热力图一格 (24×7)
export struct HeatCell {
    ratio: float,   // 0.0 ~ 1.0, 映射为紫色深浅
}

// 账号一行
export struct AccountRow {
    uid: string,
    peak: string,
    latest: string,
    limit: string,
    resets: string,
}

// 全局主题 —— 干净中性深灰黑 (参考 Timo), 集中管理便于调整
global Theme {
    out property <color> bg: #16181c;          // 窗口最深, 中性深灰黑 (不发棕)
    out property <color> panel: #1b1e23;       // 侧栏 / 面板
    out property <color> card: #22262c;        // 卡片 (比 panel 浅, 靠细边框区分)
    out property <color> card-hover: #2b2f37;
    out property <color> border: #30343c;
    out property <color> fg: #e6e8ec;          // 近白
    out property <color> fg-dim: #9aa0a8;
    out property <color> fg-mute: #686e77;
    out property <color> accent: #8b5cf6;       // 紫 (主色, 柱子也用它: 纯色饱满不塑料)
    out property <color> accent-soft: #a78bfa;
}

// --------- KPI 卡片 ---------
component KpiCard inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <string> value;
    in property <string> hint;
    background: Theme.card;
    border-radius: 14px;
    border-width: 1px;
    border-color: Theme.border;
    min-width: 170px;
    vertical-stretch: 0;
    VerticalLayout {
        padding: 16px;
        spacing: 4px;
        HorizontalLayout {
            spacing: 8px;
            Text { text: root.icon; font-size: 16px; }
            Text { text: root.label; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; }
        }
        Text { text: root.value; color: Theme.fg; font-size: 30px; font-weight: 700; }
        Text { text: root.hint; color: Theme.fg-mute; font-size: 11px; }
    }
}

// --------- 左侧导航项 ---------
component NavItem inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked;
    height: 42px;
    border-radius: 10px;
    background: root.active ? Theme.accent : transparent;
    ta := TouchArea { clicked => { root.clicked(); } }
    states [
        hover when ta.has-hover && !root.active : { background: Theme.card-hover; }
    ]
    Text {
        text: root.text;
        color: root.active ? white : Theme.fg-dim;
        font-size: 13px;
        font-weight: root.active ? 600 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component AppWindow inherits Window {
    // KPI
    in property <string> kpi-credits: "-";
    in property <string> kpi-turns: "-";
    in property <string> kpi-elapsed: "-";
    in property <string> kpi-sessions: "-";
    in property <string> kpi-turns-hint: "";
    in property <string> kpi-sessions-hint: "";
    // 柱状图
    in property <[BarItem]> bars;
    in property <string> chart-sub: "";
    // 明细表
    in property <[DetailRow]> detail-rows;
    in property <string> detail-sub: "";
    // 热力图 (7 行 × 24 列)
    in property <[[HeatCell]]> heat;
    // 账号
    in property <[AccountRow]> account-rows;
    in property <string> account-sub: "";
    // 底部
    in property <string> footer: "";
    // 当前视图: 0=简约, 1=明细(占位)
    property <int> active-view: 0;

    title: "Kiro Usage Dashboard (Slint)";
    preferred-width: 1100px;
    preferred-height: 720px;
    background: Theme.bg;

    HorizontalLayout {
        // ===== 左侧导航 =====
        Rectangle {
            width: 150px;
            background: Theme.panel;
            VerticalLayout {
                padding: 14px;
                spacing: 6px;
                // 品牌
                HorizontalLayout {
                    spacing: 8px;
                    height: 44px;
                    Text { text: "🐱"; font-size: 24px; vertical-alignment: center; }
                    VerticalLayout {
                        alignment: center;
                        Text { text: "Kiro Usage"; color: Theme.fg; font-size: 14px; font-weight: 700; }
                        Text { text: "Slint"; color: Theme.fg-mute; font-size: 10px; }
                    }
                }
                Rectangle { height: 8px; }
                NavItem {
                    text: "简约";
                    active: root.active-view == 0;
                    clicked => { root.active-view = 0; }
                }
                NavItem {
                    text: "趋势";
                    active: root.active-view == 2;
                    clicked => { root.active-view = 2; }
                }
                NavItem {
                    text: "明细";
                    active: root.active-view == 1;
                    clicked => { root.active-view = 1; }
                }
                NavItem {
                    text: "账号";
                    active: root.active-view == 3;
                    clicked => { root.active-view = 3; }
                }
                Rectangle {}  // 撑满
                Text { text: root.footer; color: Theme.fg-mute; font-size: 9px; wrap: word-wrap; }
            }
        }

        // ===== 右侧内容 =====
        Rectangle {
            background: Theme.bg;
            VerticalLayout {
                padding: 24px;
                spacing: 18px;

                // 标题
                Text {
                    text: root.active-view == 0 ? "简约"
                        : root.active-view == 1 ? "明细"
                        : root.active-view == 2 ? "趋势"
                        : "账号历史";
                    color: Theme.fg;
                    font-size: 22px;
                    font-weight: 700;
                }

                // ---- 简约视图 ----
                if root.active-view == 0 : VerticalLayout {
                    spacing: 18px;
                    // KPI 行
                    HorizontalLayout {
                        spacing: 16px;
                        KpiCard { icon: "💰"; label: "估算累计"; value: root.kpi-credits; hint: "Est. Credits"; }
                        KpiCard { icon: "💬"; label: "Turn 数"; value: root.kpi-turns; hint: root.kpi-turns-hint; }
                        KpiCard { icon: "⏱"; label: "累计耗时"; value: root.kpi-elapsed; hint: "所有 turn"; }
                        KpiCard { icon: "📁"; label: "Session"; value: root.kpi-sessions; hint: root.kpi-sessions-hint; }
                    }
                    // 柱状图
                    Rectangle {
                        background: Theme.panel;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: Theme.border;
                        VerticalLayout {
                            padding: 20px;
                            spacing: 12px;
                            HorizontalLayout {
                                Text { text: "按日 credits"; color: Theme.fg; font-size: 14px; font-weight: 600; }
                                Rectangle {}
                                Text { text: root.chart-sub; color: Theme.fg-mute; font-size: 11px; vertical-alignment: center; }
                            }
                            // 柱子区
                            HorizontalLayout {
                                alignment: space-around;
                                min-height: 200px;
                                for bar in root.bars : VerticalLayout {
                                    alignment: end;
                                    spacing: 4px;
                                    Rectangle {
                                        width: 20px;
                                        height: max(2px, bar.ratio * 170px);
                                        background: Theme.accent;
                                        border-radius: 5px;
                                    }
                                    Text {
                                        text: bar.label;
                                        color: Theme.fg-mute;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                    Rectangle {}  // 撑满
                }

                // ---- 明细视图: turn 表格 ----
                if root.active-view == 1 : VerticalLayout {
                    spacing: 10px;
                    Text { text: root.detail-sub; color: Theme.fg-mute; font-size: 12px; }
                    Rectangle {
                        background: Theme.panel;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: Theme.border;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 0px;
                            // 表头
                            Rectangle {
                                height: 34px;
                                HorizontalLayout {
                                    spacing: 12px;
                                    Text { text: "时间"; width: 128px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                                    Text { text: "credits"; width: 68px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: right; }
                                    Text { text: "耗时"; width: 68px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: right; }
                                    Text { text: "状态"; width: 66px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                                    Text { text: "workspace"; width: 140px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                                    Text { text: "title"; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                                }
                            }
                            Rectangle { height: 1px; background: Theme.border; }
                            // 数据行 (虚拟滚动)
                            ListView {
                                for row[i] in root.detail-rows : Rectangle {
                                    height: 34px;
                                    background: mod(i, 2) == 1 ? #ffffff08 : transparent;
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: row.time; width: 128px; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; }
                                        Text { text: row.credits; width: 68px; color: Theme.fg; font-size: 12px; vertical-alignment: center; horizontal-alignment: right; }
                                        Text { text: row.elapsed; width: 68px; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; horizontal-alignment: right; }
                                        Text { text: row.status; width: 66px; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; }
                                        Text { text: row.workspace; width: 140px; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; overflow: elide; }
                                        Text { text: row.title; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; overflow: elide; }
                                    }
                                }
                            }
                        }
                    }
                }

                // ---- 趋势视图: 24×7 热力图 ----
                if root.active-view == 2 : VerticalLayout {
                    spacing: 10px;
                    Text { text: "小时热力图 · 周一到周日 × 24 小时 (颜色越亮 = credits 越多)"; color: Theme.fg-mute; font-size: 12px; }
                    Rectangle {
                        background: Theme.panel;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: Theme.border;
                        vertical-stretch: 0;
                        VerticalLayout {
                            padding: 20px;
                            spacing: 6px;
                            // 列标题 (小时 0-23, 每 3 个标一个)
                            HorizontalLayout {
                                spacing: 4px;
                                Rectangle { width: 34px; }  // 行标签占位
                                for h in 24 : Text {
                                    text: mod(h, 3) == 0 ? (h < 10 ? "0" + h : h) : "";
                                    color: Theme.fg-mute;
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                            // 7 行热力
                            for row[d] in root.heat : HorizontalLayout {
                                spacing: 4px;
                                height: 22px;
                                Text {
                                    text: ["周一", "周二", "周三", "周四", "周五", "周六", "周日"][d];
                                    width: 34px;
                                    color: Theme.fg-dim;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                }
                                for cell in row : Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.accent;
                                    opacity: cell.ratio * 0.85 + 0.06;
                                    border-radius: 3px;
                                }
                            }
                        }
                    }
                    Rectangle {}  // 撑满
                }

                // ---- 账号历史视图 ----
                if root.active-view == 3 : VerticalLayout {
                    spacing: 10px;
                    Text { text: root.account-sub; color: Theme.fg-mute; font-size: 12px; }
                    Rectangle {
                        background: Theme.panel;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: Theme.border;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 0px;
                            // 表头
                            Rectangle {
                                height: 34px;
                                HorizontalLayout {
                                    spacing: 12px;
                                    Text { text: "userId"; horizontal-stretch: 1; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                                    Text { text: "峰值"; width: 90px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: right; }
                                    Text { text: "现在"; width: 90px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: right; }
                                    Text { text: "上限"; width: 80px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: right; }
                                    Text { text: "归零"; width: 60px; color: Theme.fg-dim; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: right; }
                                }
                            }
                            Rectangle { height: 1px; background: Theme.border; }
                            ListView {
                                for row[i] in root.account-rows : Rectangle {
                                    height: 40px;
                                    background: mod(i, 2) == 1 ? #ffffff08 : transparent;
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: row.uid; horizontal-stretch: 1; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; overflow: elide; }
                                        Text { text: row.peak; width: 90px; color: Theme.fg; font-size: 12px; vertical-alignment: center; horizontal-alignment: right; }
                                        Text { text: row.latest; width: 90px; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; horizontal-alignment: right; }
                                        Text { text: row.limit; width: 80px; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; horizontal-alignment: right; }
                                        Text { text: row.resets; width: 60px; color: Theme.fg-dim; font-size: 12px; vertical-alignment: center; horizontal-alignment: right; }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
