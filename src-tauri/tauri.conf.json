{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiro Usage Dashboard",
  "version": "0.1.0",
  "identifier": "com.hehuaiyu.kiro-usage-dashboard",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kiro Usage Dashboard",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "DeveloperTool",
    "shortDescription": "Local dashboard for Kiro IDE usage",
    "longDescription": "Statistics for Kiro IDE credits, sessions, and multi-account usage. All data is read locally, nothing uploaded.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
